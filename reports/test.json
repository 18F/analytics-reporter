          }
        ],
        "metrics": [
          {
            "name": "activeUsers"
          }
        ],
        "dateRanges": [
          {
            "startDate": "yesterday",
            "endDate": "yesterday"
          },
          {
            "startDate": "7daysAgo",
            "endDate": "yesterday"
          },
          {
            "startDate": "30daysAgo",
            "endDate": "yesterday"
          },
          {
            "startDate": "90daysAgo",
            "endDate": "yesterday"
          }
        ],
        "dimensionFilter": {
